# ============================================================
# The Five Agents - Environment Variables
# ============================================================
# העתק את הקובץ הזה ל-.env ומלא ערכים אמיתיים.
# קובץ .env לא נדחף ל-git (מופיע ב-.gitignore).
# ============================================================

# --- Anthropic API ---
# מפתח API של Anthropic - להפעלת מודלים של Claude.
# קבל מפתח ב: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- GitHub ---
# Personal Access Token של GitHub - לדחיפת קוד / פעולות API.
# צור טוקן ב: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxx

# --- חן (החוקרת) - מפתחות לחיפוש ברשת ---
# בחר ספק לפי הצורך (אחד מהם או יותר):
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxx
# BRAVE_SEARCH_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxx

# --- יובל (מעצב התמונות) ---
# יובל משתמש ב-OpenAI Images API דרך skill gpt-image-gen (מודל gpt-image-2).
# קבל מפתח ב: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# ספקים אלטרנטיביים (לא בשימוש כרגע):
# REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxx
# STABILITY_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# --- יעל (כותבת התוכן) ---
# כרגע משתמשת ב-ANTHROPIC_API_KEY למעלה.
# אם בעתיד תידרש אינטגרציה ל-CMS (Notion / WordPress / וכו'),
# הוסף כאן את המפתחות הרלוונטיים.
